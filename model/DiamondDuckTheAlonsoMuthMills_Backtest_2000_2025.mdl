{UTF-8}
Current Urban Land per Household=Urban Land / MAX ( 1 , Number of Households )
	~	km2/Household
	~		|

Land Demand per Household q=Housing Land Expenditure / Mean Urban Rent
	~	km2/Household
	~		|

Urban Rent Sensitivity to Land Tightness=1
	~	
	~		|

Mean Urban Rent= INTEG (( Desired Mean Urban Rent - Mean Urban Rent ) / Urban Rent Adjustment Time\
		  ,
		Initial Mean Urban Rent)
	~	EUR/km2
	~		|

Land Tightness Index=Reference Initial Land Demand per Household / MAX ( 1e-06 , Current Urban Land per Household\
		 )
	~	
	~		|

Initial Mean Urban Rent=INITIAL ( Housing Land Expenditure / Reference Initial Land Demand per Household\
		 )
	~	EUR/km2
	~		|

Urban Rent Adjustment Time=2
	~	
	~		|

Desired Mean Urban Rent=Initial Mean Urban Rent * ( Land Tightness Index ^ Urban Rent Sensitivity to Land Tightness\
		 )
	~	EUR/km2
	~		|

effektive population=WITH LOOKUP(
	    Time,
	    ([(2000,4e+08)-(2025,4.6e+08)],
	    (2000,4.28929e+08),
	    (2005,4.35116e+08),
	    (2010,4.41041e+08),
	    (2015,4.43667e+08),
	    (2020,4.47485e+08),
	    (2024,4.493e+08),
	    (2025,4.5038e+08))
	)
	~	
	~		|

Mean Household Size = WITH LOOKUP (    Time,
		    ([(2000,2)-(2025,2.6)],
		    (2000,2.5),
		    (2005,2.45),
		    (2010,2.4),
		    (2015,2.34),
		    (2020,2.3),
		    (2024,2.3),
		    (2025,2.22)))
	~	Person/Household
	~		|

Population kcal demand=Caloric Baseline Need pP * effektive population
	~	kcal
	~		|

Urban Land Percentage Error=ZIDZ ( Urban Land - Observed Urban Land , Observed Urban Land\
		 ) * 100
	~	percent
	~	Prozentualer Fehler relativ zum beobachteten Wert
	|

Number of Households=effektive population / Mean Household Size
	~	Households
	~		|

Observed Urban Land = WITH LOOKUP (Time,
		    ([(2000,150000)-(2025,190000)],
		    (2000,160000),
		    (2018,175600),
		    (2022,181700),
		    (2025,186000)))
	~	
	~	Beobachtete/approximierte EU-27 urbane Fläche für Backtesting
	|

Mean Annual Housing Cost per Capita=WITH LOOKUP(
	    Time,
	    ([(2000,4000)-(2025,10000)],
	    (2000,4700),
	    (2005,5900),
	    (2010,6700),
	    (2015,7200),
	    (2020,8300),
	    (2024,9200),
	    (2025,9800))
	)
	~	EUR/Person
	~	monat: 805
	|

Import Dependence=(effektive population*Caloric Baseline Need pP) / Food Production
	~	
	~		|

Income per Capita = WITH LOOKUP (    Time,
		    ([(2000,15000)-(2025,45000)],
		    (2000,20000),
		    (2005,25000),
		    (2010,28500),
		    (2015,30600),
		    (2020,32500),
		    (2024,39000),
		    (2025,41600)))
	~	EUR
	~		|

Crude Birth Rate = WITH LOOKUP (    Time,
		    ([(2000,0)-(2025,0.015)],
		    (2000,0.01046),
		    (2001,0.010211),
		    (2002,0.010141),
		    (2003,0.010157),
		    (2004,0.010248),
		    (2005,0.010216),
		    (2006,0.010343),
		    (2007,0.010378),
		    (2008,0.010624),
		    (2009,0.010478),
		    (2010,0.010433),
		    (2011,0.010131),
		    (2012,0.010016),
		    (2013,0.009749),
		    (2014,0.009862),
		    (2015,0.009757),
		    (2016,0.009863),
		    (2017,0.009723),
		    (2018,0.009515),
		    (2019,0.009335),
		    (2020,0.00912),
		    (2021,0.009176),
		    (2022,0.008707),
		    (2023,0.008169),
		    (2024,0.007909),
		    (2025,0.007909)))
	~	
	~	Die 0,0087 in unserem Modell ist die Crude Birth Rate (CBR) – rohe Geburtenziffer:
			•	Einheit: Geburten pro Person und Jahr (oder ‰ = pro 1000 Personen)
			•	Beantwortet: „Wie viele Babys werden pro Jahr geboren, bezogen auf die \
		Gesamtbevölkerung?“
			•	EU-27 aktuell: ca. 8,7 ‰ = 0,0087
	|

Transport Cost per km per Household=
	Transport Cost per km per Capita * Commuters per Household
	~	EUR/km/Household
	~		|

Employment Share of Total Population=0.38
	~	dmnl
	~		|

Commuters per Household=
	Commuting Share of Employed Persons * Employment Share of Total Population * Mean Household Size
	~	Commuters/Household
	~		|

Transport Cost per Household=
	Average Commuting Distance * Transport Cost per km per Household
	~	EUR/Households
	~		|

Desired Urban Land Total=
	Desired Urban Land * Urban Aggregate Scale Factor * Household Scaling Factor
	~	km2
	~		|

Household Scaling Factor=
	Number of Households / Reference Initial Number of Households
	~	dmnl
	~	Household Scaling Factor sorgt dafür, dass der EU-Zielwert mit der Zahl \
		der Haushalte wächst
	|

Reference Initial Number of Households= INITIAL(
	Number of Households)
	~	Households
	~		|

Commuting Share of Employed Persons=0.9
	~	dmnl
	~		|

Urban Aggregate Scale Factor=
	Reference Initial Urban Land / Reference Initial Desired Urban Land
	~	dmnl
	~	Urban Aggregate Scale Factor skaliert (nur) die synthetische AMM-Stadt auf \
		EU-Niveau
	|

Urban Land Gap=
	MAX ( 0 , Desired Urban Land Total - Urban Land )
	~	km2
	~		|

Reference Initial Desired Urban Land= INITIAL(
	Desired Urban Land)
	~	km2
	~		|

Additional Urban Land Needed for Clearing=
	Household Clearing Gap * Land Demand per Household q
	~	km2
	~		|

Household Capacity of Current Urban Land=
	Urban Land / Land Demand per Household q
	~	Households
	~		|

Agricultural Rent=
	30000
	~	EUR/km2
	~	Empirischer Startwert für landwirtschaftliche Bodenrente. Eurostat nennt \
		für die EU 2024 eine durchschnittliche jährliche Pacht für Ackerland \
		und Dauergrünland von 295 EUR/ha. Umrechnung: 295 EUR/ha * 100 ha/km2 = \
		29'500 EUR/km2. Gerundet: Agricultural Rent = 30000 EUR/km2. Da das Modell \
		in Jahren läuft, ist dies als EUR/km2/year zu lesen.
	|

AMM Consistent Additional Urban Land Needed=
	MIN(
	  Additional Urban Land Needed for Clearing,
	  Urban Land Gap
	)
	~	km2
	~		|

AMM Fringe Condition Gap=
	Urban Rent at Fringe - Agricultural Rent
	~	EUR/km2
	~		|

Current Urban Radius=
	SQRT(Urban Land / 3.141)
	~	km
	~		|

Initial Mean Household Size=2.5
	~	Person/Household
	~	Empirischer Startwert für durchschnittliche Haushaltsgrösse. Eurostat weist für \
		die EU rund 2.3 Personen pro Haushalt aus. Dieser Wert bleibt als \
		Initial-Referenz konstant und wird zur Kalibrierung von Reference Initial \
		Land Demand per Household verwendet
		Eurostat: 2.3 persons per household in the EU
	|

Reference Initial Land Demand per Capita=
	0.000498
	~	km2/Person
	~	Empirischer Referenzwert für urbane Landnachfrage pro Person im Startzustand. \
		JRC/LUISA nennt für EU-28 rund 498 m2 artificial area per inhabitant. \
		Umrechnung: 498 m2 = 0.000498 km2/Person.
		ABER:
		181700 / 451800000 = 0.000402 km2 pro Person
		= 402 m2 pro Person
	|

Reference Initial Land Demand per Household= INITIAL(
	Initial Mean Household Size * Reference Initial Land Demand per Capita)
	~	km2/Household
	~	Empirisch kalibrierter Startwert für urbane Landnachfrage pro Haushalt.
		
		Berechnung:
		498 m2 artificial area per capita * 2.3 persons per household
		= 1145 m2 per household
		= 0.001145 km2 per household
		
		Gerundeter Modellwert:
		Reference Initial Land Demand per Household = 0.0011 km2/Household
		
		Quellenbasis:
		JRC/LUISA: 498 m2 artificial area per inhabitant in EU-28
		Eurostat: 2.3 persons per household in the EU
	|

Average Commuting Distance=
	14
	~	km
	~	Empirischer Baseline-Wert für einfache Pendeldistanz Wohnort-Arbeitsplatz, also \
		one-way.
		 SD Worx: 28.56 km tägliche Gesamtdistanz retour ≈ 14.28 km one-way.
		BFS Schweiz: 14.0 km one-way als europäischer Plausibilitätsvergleich. Daher \
		gerundet: 14 km.
		SD Worx = privater europäischer HR-/Payroll-Dienstleister, der eigene \
		Umfragen/Reports publiziert
	|

Average Workdays per Capita=
	230
	~	dmnl
	~		|

Urban Rent at Current Fringe=
	(
	Mean Household Income
	- Other Consumption Per Household z
	- Transport Cost per km per Household * Current Urban Radius
	)
	/
	Land Demand per Household q
	~	EUR/km2
	~		|

Relative Land Demand per Household=
	Land Demand per Household q / Reference Initial Land Demand per Household
	~	dmnl
	~		|

Household Clearing Gap=
	MAX (0,  ( Number of Households - Household Capacity of Current Urban Land ))
	~	Households
	~		|

Urban Land Required for Households=
	Land Demand per Household q * Number of Households
	~	km2
	~		|

Transport Cost per km per Capita=
	2 * Average Workdays per Capita * Transport Cost per km
	~	EUR/km/Person
	~	allez-retour = 2
		arbeitstage pro jahr= 230
		mean km kosten ist "Transport Cost per km"  = 0.47 (weighted sum)
	|

Current Fringe Rent Gap=
	MAX(0, Urban Rent at Current Fringe - Agricultural Rent)
	~	EUR/km2
	~	zeigt ob die aktuelle Stadt kleiner ist als das AMM-Gleichgewicht, resp. \
		Expansionsdruck am aktuellen Rand
	|

Transport Cost per km=
	0.47
	~	cost/km
	~		|

Urban Rent at Fringe=
	(
	Mean Household Income
	- Other Consumption Per Household z
	- Transport Cost per km per Household * Urban Fringe Radius
	)
	/
	Land Demand per Household q
	~	EUR/km2
	~		|

AMM Consistent Economic Land Conversion Demand=
	AMM Consistent Additional Urban Land Needed / Urban Expansion Adjustment Time
	~	km2/Time
	~		|

Mean Annual Housing Cost per Household=
	Mean Annual Housing Cost per Capita * Mean Household Size
	~	EUR/Household
	~		|

Urban Expansion Adjustment Time=
	3
	~	Year
	~	AMM ist ein statisches Gleichgewichtsmodell und bestimmt keine \
		Anpassungsgeschwindigkeit. Urban Expansion Adjustment Time ist deshalb ein \
		dynamischer Trägheitsparameter. Er wird so kalibriert, dass Land \
		Conversion Rate ungefähr zu beobachteten EU-Land-take-Raten in km2/year \
		passt. Ist die simulierte Umwandlung zu hoch, wird die Anpassungszeit \
		erhöht. Ist sie zu niedrig, wird sie reduziert.
	|

Urban Fringe Radius=
	MAX(0,
	(Mean Household Income
	- Other Consumption Per Household z
	- Land Demand per Household q * Agricultural Rent)
	/
	Transport Cost per km per Household
	)
	~	km
	~	R(x) = RA​ mit R(x) = ( Y−z−T(x)​ ) / q
		daraus: RA​ =  ( Y−z−T(x)​ ) / q 
		und da hier T(x) ein linearer Term T(x) =( t * x ) ist ->
		umgestellt und hier verwendet als: x= ( Y−z−q * RA​​ ) / t
	|

Reference Other Consumption Per Household= INITIAL(
	Other Consumption Per Household z)
	~	EUR/Household
	~		|

Other Consumption Per Household z=
	(1 - Housing Preference Share Alpha) * Disposable Income after Transport
	~	EUR/Households
	~		|

Cobb Douglas Utility Index=
	(Relative Land Demand per Household ^ (Housing Preference Share Alpha)) * (Relative Other Consumption per Household\
		 ^ (1 - Housing Preference Share Alpha))
	~	dmnl
	~		|

Relative Other Consumption per Household=
	Other Consumption Per Household z / Reference Other Consumption Per Household
	~	dmnl
	~		|

Housing Land Expenditure=
	Housing Preference Share Alpha * Disposable Income after Transport
	~	EUR/Households
	~		|

Disposable Income after Transport=
	MAX ( 0, Mean Household Income - Transport Cost per Household)
	~	EUR/ Households
	~		|

Mean Household Income=
	Income per Capita * Mean Household Size
	~	EUR/Households
	~		|

Housing Preference Share Alpha=
	0.15
	~	dmnl
	~		|

Land per Capita=
	0.0003
	~	km2
	~	0.0003km2  mit 1 m^2 = 0.000001 km^2
	|

Desired Urban Land=
	3.141 * (Urban Fringe Radius^2)
	~	km2
	~		|

Land per Household=
	Land per Capita * Mean Household Size
	~	
	~		|

Land Conversion Pressure Factors=AMM Consistent Economic Land Conversion Demand
	~	km2/Time
	~		|

Aggricultural Land Requirement="Target Value: Populational Need of Kcal in Km2"- Aggricultural Land
	~	
	~		|

